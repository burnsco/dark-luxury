{
  "name": "dark-luxury",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.9",
  "scripts": {
    "dev": "bunx vite",
    "build": "bun run typecheck && bunx vite build",
    "preview": "bunx vite preview",
    "typecheck": "bunx tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@vitejs/plugin-react": "^4.7.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "typescript": "^5.9.3",
    "vite": "^6.4.1"
  }
}
